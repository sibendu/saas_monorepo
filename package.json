{
  "name": "saas-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:bff\"",
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:bff": "npm run dev --workspace=apps/bff",
    "build": "npm run build --workspaces",
    "build:web": "npm run build --workspace=apps/web",
    "build:bff": "npm run build --workspace=apps/bff",
    "type-check": "npm run type-check --workspaces",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "npm run test:unit --workspace=apps/web && npm run test:unit --workspace=apps/bff",
    "test:integration": "npm run test:integration --workspace=apps/web && npm run test:integration --workspace=apps/bff",
    "test:e2e": "npm run test:e2e --workspace=apps/web",
    "test:e2e:install": "npm run test:e2e:install --workspace=apps/web",
    "test:all": "npm run test && npm run test:e2e"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@prisma/client": "^7.4.2"
  }
}
